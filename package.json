{
  "name": "typeorm-transaction-helper",
  "version": "1.0.0",
  "description": "Simple and lightweight TypeORM transaction helper using QueryRunner",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "typeorm",
    "transaction",
    "helper",
    "database",
    "queryrunner"
  ],
  "author": "jeongjimin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hijiji/typeorm-transaction-helper.git"
  },
  "homepage": "https://github.com/Hijiji/typeorm-transaction-helper",
  "bugs": {
    "url": "https://github.com/Hijiji/typeorm-transaction-helper/issues"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist coverage",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test:cov"
  },
  "peerDependencies": {
    "typeorm": "^0.3.0 || ^0.4.0"
  },
  "peerDependenciesMeta": {
    "typeorm": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
